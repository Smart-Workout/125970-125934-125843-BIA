# ============================================================
# Smart Workout — .gitignore
# ============================================================

# External/reference documents intentionally not committed
final_report_KaungHeinHtet.pdf
references/external/

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# === Virtual environments ===
venv/
.venv/
env/

# === IDE / Editor ===
.vscode/
.idea/
.claude/
*.swp
*.swo

# === Environment variables (NEVER commit secrets / API keys) ===
.env
.env.local
.env.*

# === OS ===
.DS_Store
Thumbs.db

# === Office temp lock files (e.g. ~$BIA Initial Idea.docx) ===
~$*

# === Backups ===
*.bak

# === Jupyter ===
.ipynb_checkpoints/

# === Test / Coverage ===
.coverage
htmlcov/
.pytest_cache/

# === Logs ===
*.log

# === LaTeX build artifacts (proposal.pdf stays tracked) ===
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.out
*.toc
*.synctex.gz

# === Node / React (when frontend gets built) ===
node_modules/
frontend/dist/
frontend/vite.log
frontend/vite.err
/package-lock.json

# === ChromaDB local storage (when RAG gets set up) ===
chroma_db/
chromadb_storage/

# === Local presentation / screenshot working files ===
image_progress/
